#!/bin/bash

PROJ_NAME=poppler
PROJ_DESC="a PDF processing library with utilities"
EXE=pdfunite
DIR_REL="utils"

ISSUES=(
  1282 # SIGABRT at poppler/PDFDoc.cc:1755
  1289 # SIGABRT at Object.h:445
  1303 # Segment fault in pdftops
  1305 # Reachable abort in gmem.h:112
  1381 # Stack overflow in GooString.h:241
)

COMMITS_BIC=(
    3d35d20 # Avoid cycles in PDF parsing …
    3cae777 # pdfunite: add fields to AcroForm dict …
    e674ca6 # Create fallback fonts as needed. …
    aaf2e80 # Tweak the don't use Appearance stream if annot is typeHighlight …
    245abad # Change Function::getToken return a GooString instead of a pointer …
)

COMMITS_FIX=(
    4564a00 # pdfunite: Fix crash on broken files
    efb6868 # pdfunite: Don't crash in broken documents
    a4ca3a9 # topIdx can't be negative …
    907d05a # Fix crash in file that wants to do huge transparency group …
    1be35ee # Fix stack overflow in PostScriptFunction::parseCode …
)

COMMITS=(${COMMITS_BIC[@]})
if [ "$SCENARIO" == "FIX" ]; then
    COMMITS=(${COMMITS_FIX[@]})
fi

COMMANDS=(
    "pdfunite @@ @@ /tmp/out.pdf"
    "pdfunite @@ @@ /tmp/out.pdf"
    "pdftops @@ /dev/null"
    "pdftoppm -mono -cropbox @@"
    "pdftoppm -mono -cropbox @@"
)

declare -A COMMANDS_MAP
for i in "${!COMMITS[@]}"; do
    COMMANDS_MAP[${COMMITS_BIC[$i]}]="${COMMANDS[$i]}"
    COMMANDS_MAP[${COMMITS_FIX[$i]}]="${COMMANDS[$i]}"
done

clone_repo() {
  git clone https://gitlab.freedesktop.org/poppler/poppler/
  git config --global --add safe.directory $PWD/$PROJ_NAME
}

pre_build() {
  local builddir=$1
  git restore .
}

post_build() {
  local builddir=$1
  if [ ! -f $builddir/$DIR_REL/$EXE ]; then
    echo "ERROR: $builddir/$DIR_REL/$EXE did not build"
    exit 1
  fi

  # if buildafl, check for __afl in EXE symbols
  if [[ $builddir == buildafl* ]]; then
    if [ -z "$(nm -an $builddir/$DIR_REL/$EXE | grep __afl)" ]; then
      echo "ERROR: $builddir/$DIR_REL/$EXE does not have afl symbols"
      exit 1
    fi
  # else check for gcov in EXE symbols
  else
    # if [ -z "$(nm -an $builddir/$DIR_REL/$EXE | grep __gcov)" ]; then
    #   echo "ERROR: $builddir/$DIR_REL/$EXE does not have gcov symbols"
    #   exit 1
    # fi
    # also check for .gcno files in $builddir
    if [ -z "$(find $builddir -name '*.gcno')" ]; then
      echo "ERROR: $builddir does not have .gcno files"
      exit 1
    fi
  fi
  
  git restore .
}

# PWD is root of project repo for funcs below
build_target() {
  local commit=$(git rev-parse --short=7 HEAD)
  local builddir=${1:-build_$commit}
  
  export CFLAGS_ASAN="-fsanitize=address -fno-omit-frame-pointer"
  export LDFLAGS_ASAN="-fsanitize=address -fno-omit-frame-pointer"
  export CFLAGS_GCOV="-fprofile-arcs -ftest-coverage -DFUZZING_BUILD_MODE_UNSAFE_FOR_PRODUCTION"
  export LDFLAGS_GCOV="-lgcov --coverage"
  export CFLAGS="$CFLAGS_ASAN $CFLAGS_GCOV"
  export LDFLAGS="$LDFLAGS_ASAN $LDFLAGS_GCOV"
  export CMAKE_OPTS="-DENABLE_LIBCURL=OFF -DENABLE_GPGME=OFF -DENABLE_QT5=OFF -DENABLE_QT6=OFF -DENABLE_BOOST=OFF -DENABLE_LIBOPENJPEG=none -DENABLE_LCMS=OFF -DENABLE_GLIB=OFF"
  ./afl-cov-build.sh cmake -G Ninja -S . -B $builddir $CMAKE_OPTS
  ninja -C $builddir -j64
  unset CFLAGS LDFLAGS
}

buildafl_target() {
  local commit=$(git rev-parse --short=7 HEAD)
  local builddir=${1:-buildafl_$commit}
  
  export CC="afl-clang-fast"
  export CXX="afl-clang-fast++"
  export AFL_USE_ASAN=1
  export CMAKE_OPTS="-DENABLE_LIBCURL=OFF -DENABLE_GPGME=OFF -DENABLE_QT5=OFF -DENABLE_QT6=OFF -DENABLE_BOOST=OFF -DENABLE_LIBOPENJPEG=none -DENABLE_LCMS=OFF -DENABLE_GLIB=OFF"
  cmake -G Ninja -S . -B $builddir $CMAKE_OPTS
  ninja -C $builddir -j64
  unset CC CXX
}

buildwaflgo_target() {( set -e
  local commit=$(git rev-parse --short=7 HEAD)
  local builddir=${1:-buildwaflgo_$commit}
  local command=${COMMANDS_MAP[$commit]}
  local exe=$(echo $command | cut -d' ' -f1)
  
# see https://github.com/He1loNice/WAFLGo
  export ADD="-g --notI "
  export CC=/home/WAFLGo/afl-clang-fast CXX=/home/WAFLGo/afl-clang-fast++  CFLAGS="$ADD" CXXFLAGS="$ADD"
  export AFL_CC=gclang AFL_CXX=gclang++
  # NOTE: WAFLGo doesn't enable ASAN as it increase difficulty of instrumentation
  # export AFL_USE_ASAN=1

  # actually build before bugfix commit as bug should be triggered before 
  if [ "$SCENARIO" = "FIX" ]; then
    git checkout $commit^
  fi
  # try to disable shared lib, but #1289 BIC 3cae777 doesn't support, have to check .so later when linking
  cmake -G Ninja -S . -B $builddir -DCMAKE_BUILD_TYPE=Debug -DBUILD_SHARED_LIBS=OFF -DCMAKE_EXPORT_COMPILE_COMMANDS=ON -DCMAKE_PREFIX_PATH="/usr/lib/x86_64-linux-gnu;$CMAKE_PREFIX_PATH"
  ninja -C $builddir -j64
  git checkout $commit  # checkout back to commit so commit.diff is correct

  # ** Get bitcode file from executable file
  pushd $builddir/$DIR_REL
  get-bc $exe  # will generate $exe.bc

  # ** Set the target site
  echo $'' > $TMP_DIR/BBtargets.txt
  git diff HEAD^1 HEAD > ./commit.diff
  cp /home/showlinenum.awk .
  sed -i -e 's/\r$//' showlinenum.awk
  chmod +x showlinenum.awk
  cat ./commit.diff |  ./showlinenum.awk show_header=0 path=1 | grep -e "\.[ch]:[0-9]*:+" -e "\.cpp:[0-9]*:+" -e "\.cc:[0-9]*:+" | cut -d+ -f1 | rev | cut -c2- | rev > ./targets

  # ** Instrument
  /home/WAFLGo/instrument/bin/cbi --targets=targets $exe.bc --stats=false
  cp ./targets_id.txt /home
  cp ./suffix.txt /home
  cp ./targets*.txt /home
  cp ./distance.txt /home
  cp ./branch-distance.txt /home
  cp ./branch-distance-min.txt /home
  cp ./branch-curloc.txt /home
  cp ./*_data.txt /home

  # ** Compile bitcode file to executable file which is used to be fuzzed
  link_opts="-lfreetype -lfontconfig -ljpeg -lopenjp2 -lpng -lm -lz -llcms2 -lcurl -lnss3 -lnspr4 -lplc4 -lplds4 -lsmime3"
  # if add -L.. -lpoppler to link if .so found in ..
  [ -f ../libpoppler.so ] && link_opts+=" -L.. -lpoppler"
  /home/WAFLGo/afl-clang-fast++ $exe.ci.bc $link_opts -o $exe.ci
  cp ./bbinfo-fast.txt /home/bbinfo-ci-bc.txt
  cp ./branch-distance-order.txt /home
  cp ./*-distance-order.txt /home
  cp ./*-order.txt /home
  
  popd
)}

post_buildwaflgo() {
  local commit=$(git rev-parse --short=7 HEAD)
  local builddir=${1:-buildwaflgo_$commit}
  local command=${COMMANDS_MAP[$commit]}
  local exe=$(echo $command | cut -d' ' -f1)
  # assert $exe, $exe.bc and $exe.ci files exist in $builddir
  if [ ! -f $builddir/$DIR_REL/$exe ]; then
    echo "ERROR: $builddir/$DIR_REL/$exe did not build"
    exit 1
  fi
  if [ ! -f $builddir/$DIR_REL/$exe.bc ]; then
    echo "ERROR: $builddir/$DIR_REL/$exe.bc did not build"
    exit 1
  fi
  if [ ! -f $builddir/$DIR_REL/$exe.ci ]; then
    echo "ERROR: $builddir/$DIR_REL/$exe.ci did not build"
    exit 1
  fi
  git restore .
}

run_waflgo() {( set -e
  local commit=$(git rev-parse --short=7 HEAD)
  local builddir=${1-buildwaflgo_$commit}
  local command=${COMMANDS_MAP[$commit]}
  if [ -z "$command" ]; then
    echo "ERROR: No command found for commit $commit"
    exit 1
  fi
  # get exe from $command
  local exe=$(echo $command | cut -d' ' -f1)
  # concat new cmd with exe
  cmd="${exe}.ci $(echo $command | cut -d' ' -f2-)"
  export LD_LIBRARY_PATH=$LD_LIBRARY_PATH:/home/$PROJ_NAME/$builddir/  # have to find libpoppler.so when building shared lib 
  /home/WAFLGo/afl-fuzz -T waflgo-$PROJ_NAME -t 1000+ -m none -z exp -c 45m -q 1 -i /home/seeds/general_evaluation/pdf -o /home/out -- /home/$PROJ_NAME/$builddir/$DIR_REL/$cmd
)}

gen_cov() {
# pre-condition: CWD is repo root, may checkout to commit^ or commit
  local builddir=$1
  local commit=$(echo $builddir | sed -n 's/.*_\(.*\)/\1/p')
  local changed_files=${2-"$(git diff --name-only $commit^ $commit)"}
  local cnt=$3
  # gcda_files=$(find $builddir -name "*.gcda")
  # for gcda in $gcda_files; do
  #     gcov -r -H -o $gcda $changed_files
  # done
  for file in $changed_files; do
      filename=$(basename $file)
      # find gcda object file in $builddir_before by each file name
      gcda=$(find $builddir -name $filename.gcda)
      if [[ "$gcda" ]]; then
          gcovtxt=$(gcov -t -H -o $gcda $file)
      else
          echo "No $filename.gcda found for $file in $builddir."
      fi
      # if $builddir contain "before", mv gcov file to $filename.gcov.before_$commit.$cnt
      # otherwise, mv gcov file to $filename.gcov.after_$commit.$cnt
      if [[ $builddir == *before* ]]; then
          # mv $filename.gcov $filename.gcov.before_$commit.$cnt
          echo "$gcovtxt" > $filename.gcov.before_$commit.$cnt
      else
          # mv $filename.gcov $filename.gcov.after_$commit.$cnt
          echo "$gcovtxt" > $filename.gcov.after_$commit.$cnt
      fi
  done
  rm *.gcov
}

check_cov() {
# check overlap of commit affected lines and covered lines
# pre-condition: CWD is repo root, where .gcov files are generated
  local commit=${1-"$(git rev-parse --short=7 HEAD)"}
  local changed_file=${2-"$(git diff --name-only HEAD^ HEAD)"}
  local cnt=$3
  cover_before=""
  cover_after=""
  for file in $changed_files; do
      filename=$(basename $file)
      gcov_before=$filename.gcov.before_$commit.$cnt
      gcov_after=$filename.gcov.after_$commit.$cnt
      if [ ! -f $gcov_before ] || [ ! -f $gcov_after ]; then
          echo "No gcov report found for $file before/after commit $commit, skipping." | tee -a $chat_log
          continue
      else
          echo "Checking covered lines in $gcov_before and $gcov_after." | tee -a $chat_log
      fi
      changed_lines=$(commit_affected_lines "$commit" "$file")
      lines_before=$(echo "$changed_lines" | sed -n 's/^lines_before://p')
      lines_after=$(echo "$changed_lines" | sed -n 's/^lines_after://p')
      echo "commit $commit^ affected lines in $file: $lines_before" | tee -a $chat_log
      echo "commit $commit affected lines in $file: $lines_after" | tee -a $chat_log
      cover_lines_before=()
      # read -p "Pause for debug. Press any key to continue..."
      for line in ${lines_before//,/ }; do
          # determine if line is coveraged in pre-commit gcov report
          covered_lines=$(cat $gcov_before | grep -v '^\s*-' | grep -v '^\s*#####')
          pat="^[[:blank:]]*.*:[[:blank:]]*$line:.*$"  # before second colon in each line
          if [[ $covered_lines =~ $pat ]]; then
              cover_lines_before+=($line)
              # echo "Line $line in $file is covered before commit $commit." | tee -a $chat_log
          fi
      done
      if [ ${#cover_lines_before[@]} -gt 0 ]; then
          cover_before+="$filename:${cover_lines_before[@]}\n"
      fi
      cover_lines_after=()
      for line in ${lines_after//,/ }; do
          # determine if line is coveraged in post-commit gcov report
          covered_lines=$(cat $gcov_after | grep -v '^\s*-' | grep -v '^\s*#####')
          pat="^[[:blank:]]*.*:[[:blank:]]*$line:.*$"  # before second colon in each line
          if [[ $covered_lines =~ $pat ]]; then
              cover_lines_after+=($line)
              # echo "Line $line in $file is covered after commit $commit." | tee -a $chat_log
          fi
      done
      if [ ${#cover_lines_after[@]} -gt 0 ]; then
          cover_after+="$filename:${cover_lines_after[@]}\n"
      fi
  done
  # return true if $cover_before or $cover_after is not empty
  if [ -n "$cover_before" ] || [ -n "$cover_after" ]; then
      return $(true)
  else
      return $(false)
  fi
}